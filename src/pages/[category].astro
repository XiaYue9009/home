---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../consts';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  return Object.keys(CATEGORIES).map((category) => ({ params: { category } }));
}) satisfies GetStaticPaths;

const { category } = Astro.params as { category: keyof typeof CATEGORIES };
const cat = CATEGORIES[category];

const posts = (await getCollection('posts', ({ data }) => !data.draft && data.category === category))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={cat.label} description={`${cat.label}分类下的全部文章`}>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <span class="text-4xl">{cat.emoji}</span>
      <h1 class={`mt-3 font-display text-3xl font-bold ${cat.color}`}>{cat.label}</h1>
      <p class="mt-2 text-muted">共 {posts.length} 篇文章</p>
    </header>

    {
      posts.length === 0 ? (
        <p class="text-subtle">暂无文章，去 src/content/posts/ 添加 Markdown 吧。</p>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
