---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LolHeroProfile from '../../components/LolHeroProfile.astro';
import LolMatchupTable from '../../components/LolMatchupTable.vue';
import { FEATURED_LOL_HERO_IDS, fetchLolHeroDetail } from '../../lib/lol';
import { getLolMatchups } from '../../data/lol-matchups';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
  return FEATURED_LOL_HERO_IDS.map((heroId) => ({ params: { heroId } }));
}

const { heroId } = Astro.params;

let hero;
try {
  hero = await fetchLolHeroDetail(heroId);
} catch {
  return Astro.redirect(withBase('lol'));
}

const matchups = getLolMatchups(heroId);
---

<BaseLayout
  fitViewport
  title={`${hero.name} · LOL`}
  description={`${hero.fullName} ${hero.name} · 对线笔记`}
>
  <div class="lol-detail-page mx-auto w-full max-w-[100rem] px-3 sm:px-4">
    <a href={withBase('lol')} class="lol-detail-page__back text-link text-sm">← 返回 LOL</a>

    <div class="lol-detail-grid">
      <LolHeroProfile hero={hero} compact artOnly />
      <div class="lol-detail-grid__main">
        <LolHeroProfile hero={hero} barText />
        <div class="lol-detail-grid__panel">
          <LolMatchupTable client:load compact matchups={matchups} heroName={hero.name} heroId={heroId} />
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style lang="scss">
  .lol-detail-page {
    display: flex;
    flex: 1;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
    padding-block: 0.375rem 0.5rem;

    &__back {
      flex-shrink: 0;
      margin-bottom: 0.4rem;
      white-space: nowrap;
    }
  }

  .lol-detail-grid {
    display: grid;
    flex: 1;
    gap: 0.65rem;
    min-height: 0;
    overflow: hidden;

    > * {
      min-height: 0;
      min-width: 0;
    }

    @media (min-width: 1024px) {
      grid-template-columns: minmax(260px, 320px) minmax(0, 1fr);
      align-items: stretch;
    }

    @media (max-width: 1023px) {
      grid-template-rows: minmax(7.5rem, 20vh) minmax(0, 1fr);
    }

    &__main {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      min-height: 0;
      overflow: hidden;

      > :first-child {
        flex-shrink: 0;
      }
    }

    &__panel {
      display: flex;
      flex: 1;
      flex-direction: column;
      min-height: 0;
      overflow: hidden;

      :global(> astro-island) {
        display: flex;
        flex: 1;
        flex-direction: column;
        min-height: 0;
        overflow: hidden;
      }
    }
  }
</style>
