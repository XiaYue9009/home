---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NatureFall from '../components/NatureFall.vue';
import '../styles/global.scss';
import { DEFAULT_THEME, THEME_STORAGE_KEY } from '../config/themes';

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme={DEFAULT_THEME}>
  <head>
    <BaseHead title={title} description={description} />
    <script is:inline define:vars={{ storageKey: THEME_STORAGE_KEY, defaultTheme: DEFAULT_THEME }}>
      (function () {
        var t = localStorage.getItem(storageKey) || defaultTheme;
        if (t !== 'nature' && t !== 'minimal' && t !== 'night') t = defaultTheme;
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <NatureFall client:load />
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html {
    scrollbar-gutter: stable;
  }

  @keyframes theme-glow {
    0% {
      box-shadow: 0 0 16px var(--color-btn-shadow);
    }
    100% {
      box-shadow: 0 0 32px var(--color-btn-shadow);
    }
  }

  .animate-glow {
    animation: theme-glow 3s ease-in-out infinite alternate;
  }
</style>
