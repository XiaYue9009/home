---
import BaseLayout from './BaseLayout.astro';
import GiscusComments from '../components/GiscusComments.vue';
import { CATEGORIES, formatDate } from '../consts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const { Content } = await post.render();
const cat = CATEGORIES[category];
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header class="mb-10">
      <a
        href={`/${category}`}
        class={`mb-4 inline-flex items-center gap-1.5 text-sm font-medium ${cat.color}`}
      >
        <span>{cat.emoji}</span>
        <span>{cat.label}</span>
      </a>
      <h1 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {title}
      </h1>
      <p class="mt-3 text-slate-400">{description}</p>
      <time datetime={pubDate.toISOString()} class="mt-4 block text-sm text-slate-500">
        {formatDate(pubDate)}
      </time>
      {
        tags.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <li class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-300">
                #{tag}
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose-moon">
      <Content />
    </div>

    <section class="mt-16 border-t border-white/10 pt-10">
      <h2 class="mb-6 font-display text-xl font-semibold text-white">评论</h2>
      <GiscusComments client:visible />
    </section>
  </article>
</BaseLayout>
