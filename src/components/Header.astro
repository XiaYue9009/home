---
import { SITE, CATEGORIES } from '../consts';

const navLinks = [
  { href: '/', label: '首页' },
  ...Object.entries(CATEGORIES).map(([key, val]) => ({
    href: `/${key}`,
    label: val.label,
  })),
  { href: '/about', label: '关于' },
];

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/80 backdrop-blur-lg">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <a href="/" class="group flex items-center gap-2">
      <span class="text-2xl transition-transform group-hover:scale-110">🌙</span>
      <span class="font-display text-lg font-bold tracking-tight text-white">{SITE.title}</span>
    </a>

    <nav class="hidden items-center gap-1 sm:flex">
      {
        navLinks.map(({ href, label }) => {
          const active = href === '/' ? pathname === href : pathname.startsWith(href);
          return (
            <a
              href={href}
              class:list={[
                'rounded-full px-4 py-2 text-sm font-medium transition',
                active
                  ? 'bg-moon-600/20 text-moon-200'
                  : 'text-slate-400 hover:bg-white/5 hover:text-white',
              ]}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <a
      href={SITE.github}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-ghost hidden sm:inline-flex"
      aria-label="GitHub"
    >
      GitHub
    </a>
  </div>
</header>
