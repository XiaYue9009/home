---
import { formatDate, CATEGORIES } from '../consts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const cat = CATEGORIES[category];
---

<a
  href={`/posts/${post.slug}`}
  class="glass-card group block p-6 transition hover:border-moon-500/30 hover:bg-white/[0.07]"
>
  <div class="mb-3 flex items-center justify-between gap-2">
    <span class={`inline-flex items-center gap-1 text-xs font-medium ${cat.color}`}>
      <span>{cat.emoji}</span>
      <span>{cat.label}</span>
    </span>
    <time datetime={pubDate.toISOString()} class="text-xs text-slate-500">
      {formatDate(pubDate)}
    </time>
  </div>
  <h2 class="font-display text-lg font-semibold text-white transition group-hover:text-moon-200">
    {title}
  </h2>
  <p class="mt-2 line-clamp-2 text-sm text-slate-400">{description}</p>
  {
    tags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <li class="rounded-md bg-slate-800/80 px-2 py-0.5 text-xs text-slate-400">#{tag}</li>
        ))}
      </ul>
    )
  }
</a>
