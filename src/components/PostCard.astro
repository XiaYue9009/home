---
import { formatDate, CATEGORIES } from '../config/consts';
import { withBase } from '../lib/paths';

const { post } = Astro.props;
const { title, description, pubDate, category, tags } = post.data;
const cat = CATEGORIES[category];
---

<a
  href={withBase(`posts/${post.slug}`)}
  class="glass-card glass-card-hover group block p-6 transition"
>
  <div class="mb-3 flex items-center justify-between gap-2">
    <span class={`inline-flex items-center gap-1 text-xs font-medium ${cat.color}`}>
      <span>{cat.emoji}</span>
      <span>{cat.label}</span>
    </span>
    <time datetime={pubDate.toISOString()} class="text-xs text-subtle">
      {formatDate(pubDate)}
    </time>
  </div>
  <h2 class="font-display text-lg font-semibold text-heading transition group-hover:text-accent-soft">
    {title}
  </h2>
  <p class="mt-2 line-clamp-2 text-sm text-muted">{description}</p>
  {
    tags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <li class="tag-pill rounded-md px-2 py-0.5 text-xs">#{tag}</li>
        ))}
      </ul>
    )
  }
</a>
