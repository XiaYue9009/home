# Giscus 评论配置（https://giscus.app/zh-CN 生成后填入）
PUBLIC_GISCUS_REPO=XiaYue9009/home
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=Announcements
PUBLIC_GISCUS_CATEGORY_ID=

# 天气（浏览器未授权定位时使用，数据来源 Open-Meteo）
PUBLIC_WEATHER_CITY=北京
PUBLIC_WEATHER_DISTRICT=东城区
PUBLIC_WEATHER_LAT=39.9042
PUBLIC_WEATHER_LON=116.4074

# LOL 云端同步：我的英雄 + 对线笔记（Supabase，可选）
# 未配置时仅使用浏览器 localStorage
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
# db push 时使用（Dashboard → Project Settings → Database → Database password）
SUPABASE_DB_PASSWORD=

# GitHub 图床（本地与线上统一走 Supabase Edge Function upload-github-image）
# GITHUB_TOKEN 仅存 Supabase Secret，不要写在 .env
# 部署：supabase secrets set GITHUB_TOKEN=... && supabase functions deploy upload-github-image
# PUBLIC_GITHUB_UPLOAD_SECRET=
# PUBLIC_GITHUB_IMAGE_API_BASE=

# 抖音「我的收藏夹」：按关键词模糊匹配（默认：旅游、美食，名称包含即匹配）
# 数据持久化在 Supabase；每月 1/16 号自动增量同步，其余时间读库
DOUYIN_COOKIE=
PUBLIC_DOUYIN_MAX_VIDEOS=60
# 关键词，逗号分隔（收藏夹名称包含即归入该组）
PUBLIC_DOUYIN_COLLECTS_FOLDERS=旅游,美食
# 可选：生产环境自建代理地址（本地 dev 走 Vite 代理）
PUBLIC_DOUYIN_API_BASE=
